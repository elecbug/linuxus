# =========================
# Paths
# =========================
LOGIN_PATH=login
LOGOUT_PATH=logout
SERVICE_PATH=service
TERMINAL_PATH=terminal

# =========================
# Auth Service Container
# =========================
AUTH_PORT=8080
AUTH_SOURCE_DIR=./auth
AUTH_CONTAINER_NAME=linuxus_auth
AUTH_LIST_MOUNT_PATH=/data/AUTH_LIST
SESSION_SECRET=change-this-secret-before-production

# =========================
# User Service Containers
# =========================
SERVICE_SOURCE_DIR=./service
SERVICE_CONTAINER_NAME_PREFIX=linuxus_service_
USERNAME_PREFIX=stu-
SERVICE_HOSTNAME=linuxus

# =========================
# Manager Container
# =========================
MANAGER_CONTAINER_NAME=linuxus_manager
MANAGER_CONTAINER_USERNAME=manager
MANAGER_LOGIN_ID=admin
MANAGER_LOGIN_PASSWORD=admin

# =========================
# Compose
# =========================
OUTPUT_FILE=docker-compose.generated.yml

# =========================
# Host Volumes
# =========================
HOST_DATA_DIR=./data
HOST_HOMES_DIR=${HOST_DATA_DIR}/homes
HOST_SHARE_DIR=${HOST_DATA_DIR}/share
HOST_READONLY_DIR=${HOST_DATA_DIR}/readonly

SERVICE_SHARED_DIR=/home/share
SERVICE_READONLY_DIR=/home/readonly
