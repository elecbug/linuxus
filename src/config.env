# =========================
# URL Paths
# =========================
URL_LOGIN_PATH=login
URL_LOGOUT_PATH=logout
URL_SERVICE_PATH=service
URL_TERMINAL_PATH=terminal

# =========================
# Auth Service Container
# =========================
AUTH_EXTERNAL_PORT=8080
AUTH_SOURCE_DIR=./auth
AUTH_CONTAINER_NAME=linuxus_auth
AUTH_LIST_FILE=./data/AUTH_LIST
AUTH_LIST_MOUNT_PATH=/data/AUTH_LIST
AUTH_SESSION_SECRET=change-this-secret-before-production

# =========================
# Container Runtime
# =========================
CONTAINER_RUNTIME_UID=1000
CONTAINER_RUNTIME_GID=1000
CONTAINER_RUNTIME_USER=linuxus

# =========================
# User Service Containers
# =========================
USER_SOURCE_DIR=./service
USER_CONTAINER_NAME_PREFIX=linuxus_service_
USER_HOSTNAME=linuxus
USER_PREFIX=user-
USER_NETWORK_PREFIX=net_user_
USER_BASE_IP="10.10.1.0"

USER_CPU_LIMIT=1.5
USER_MEMORY_LIMIT=512m
USER_PID_LIMIT=128
USER_ULIMITS_NOFILE_SOFT=1024
USER_ULIMITS_NOFILE_HARD=2048
USER_DISK_LIMIT=512 # MB

# USER_NETWORK_BANDWIDTH_LIMIT=10mbit
# USER_SESSION_TIMEOUT=3600

# =========================
# Admin Container
# =========================
ADMIN_SOURCE_DIR=${USER_SOURCE_DIR}
ADMIN_CONTAINER_NAME_PREFIX=${USER_CONTAINER_NAME_PREFIX}
ADMIN_HOSTNAME=${USER_HOSTNAME}
ADMIN_PREFIX=admin-
ADMIN_USER_ID=alpha
ADMIN_NETWORK_PREFIX=net_admin_
ADMIN_BASE_IP=${USER_BASE_IP}

ADMIN_CPU_LIMIT=1.5
ADMIN_MEMORY_LIMIT=512m
ADMIN_PID_LIMIT=128
ADMIN_ULIMITS_NOFILE_SOFT=1024
ADMIN_ULIMITS_NOFILE_HARD=2048
ADMIN_DISK_LIMIT=512 # MB

# =========================
# Compose
# =========================
OUTPUT_FILE=docker-compose.generated.yml

# =========================
# Host Volumes
# =========================
HOST_DATA_DIR=./volumes
HOST_HOMES_DIR=${HOST_DATA_DIR}/homes
HOST_SHARE_DIR=${HOST_DATA_DIR}/share
HOST_READONLY_DIR=${HOST_DATA_DIR}/readonly

# =========================
# Container Volumes
# =========================
CONTAINER_SHARE_DIR=/home/share
CONTAINER_READONLY_DIR=/home/readonly
