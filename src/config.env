# ==================================
# User Service Container Runtime
# ==================================
CONTAINER_RUNTIME_UID=1000
CONTAINER_RUNTIME_GID=1000
CONTAINER_RUNTIME_USER=user
CONTAINER_RUNTIME_HOSTNAME=linuxus
CONTAINER_TIMEZONE=America/New_York

# ==================================
# User Service Containers
# ==================================
USER_SOURCE_DIR=./service
USER_CONTAINER_NAME_PREFIX=linuxus_user_
USER_NETWORK_PREFIX=linuxus_user_net_
USER_BASE_IP="10.10.1.0"

# ==================================
# Admin Container
# ==================================
ADMIN_USER_ID=alpha

# ==================================
# User Computing Resource Limits
# ==================================
USER_CPU_LIMIT=1.5
USER_MEMORY_LIMIT=512m
USER_PID_LIMIT=128
USER_ULIMITS_NOFILE_SOFT=1024
USER_ULIMITS_NOFILE_HARD=2048
USER_DISK_LIMIT=512 # MB
# USER_NETWORK_BANDWIDTH_LIMIT=10mbit
# USER_SESSION_TIMEOUT=3600

# ==================================
# Admin Computing Resource Limits 
# - Same as user limits for now
# ==================================
ADMIN_CPU_LIMIT=${USER_CPU_LIMIT}
ADMIN_MEMORY_LIMIT=${USER_MEMORY_LIMIT}
ADMIN_PID_LIMIT=${USER_PID_LIMIT}
ADMIN_ULIMITS_NOFILE_SOFT=${USER_ULIMITS_NOFILE_SOFT}
ADMIN_ULIMITS_NOFILE_HARD=${USER_ULIMITS_NOFILE_HARD}
ADMIN_DISK_LIMIT=${USER_DISK_LIMIT} # MB
# ADMIN_NETWORK_BANDWIDTH_LIMIT=${USER_NETWORK_BANDWIDTH_LIMIT}
# ADMIN_SESSION_TIMEOUT=${USER_SESSION_TIMEOUT}

# ==================================
# Volumes
# ==================================
HOST_VOLUME_DIR=./volumes
HOST_HOMES_DIR=${HOST_VOLUME_DIR}/homes
HOST_SHARE_DIR=${HOST_VOLUME_DIR}/share
HOST_READONLY_DIR=${HOST_VOLUME_DIR}/readonly

CONTAINER_SHARE_DIR=/home/share
CONTAINER_READONLY_DIR=/home/readonly

# ==================================
# URL Paths
# ==================================
URL_LOGIN_PATH=login
URL_LOGOUT_PATH=logout
URL_SERVICE_PATH=service
URL_TERMINAL_PATH=terminal

# ==================================
# Auth Service Container
# ==================================
AUTH_EXTERNAL_PORT=8080
AUTH_TIMEZONE=America/New_York
AUTH_SOURCE_DIR=./auth
AUTH_CONTAINER_NAME=linuxus_auth
AUTH_LIST_FILE=./data/AUTH_LIST
AUTH_LIST_MOUNT_PATH=/data/AUTH_LIST
AUTH_SESSION_SECRET=change-this-secret-before-production
AUTH_TRUSTED_PROXIES=

# ==================================
# Compose
# ==================================
OUTPUT_FILE=docker-compose.generated.yml
